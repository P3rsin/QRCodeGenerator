{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build my QRCodeGenerator project",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/QRCodeManager.cpp",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Builds both my main file and QRCodeManager file."
        }
    ],
    "version": "2.0.0"
}